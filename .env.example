# ==========================================================================
# Unified Communication Platform — Environment Configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ==========================================================================

# ---- Core ----
ENVIRONMENT=development           # development | staging | production
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string

# ---- Database (Neon Postgres) ----
# Provide ONLY this (asyncpg driver). IMPORTANT: param is `ssl=require`, not `sslmode=require`.
# Example: postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?ssl=require
# DATABASE_URL_SYNC is auto-derived from DATABASE_URL (for Alembic). Leave unset unless overriding.
# DATABASE_URL_SYNC=

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Auth / Sessions ----
SESSION_COOKIE_NAME=ucaas_session
SESSION_TTL_SECONDS=604800        # 7 days
SESSION_COOKIE_SECURE=false       # true in production (HTTPS)
SESSION_COOKIE_SAMESITE=lax

# ---- CORS ----
FRONTEND_ORIGIN=http://localhost:3000

# ---- AI (Phase 4 / MVP US2) — Google Gemini via OpenAI Agents SDK ----
# One key powers both chat + embeddings. Set your Gemini API key here.
GEMINI_API_KEY=
# Chat model (OpenAI-compatible endpoint). Use an available model id, e.g.
# gemini-2.5-flash, gemini-2.5-flash-lite, gemini-3.5-flash, etc.
LLM_MODEL=gemini-2.5-flash
# Embeddings: gemini-embedding-001 truncated to 1536 dims (fits pgvector). Usually leave as-is.
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIM=1536

# ---- Channels (Phase 3 / MVP US1) ----
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ---- Frontend (Next.js public vars) ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
